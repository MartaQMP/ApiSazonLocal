@model List<Pedido>
@{
    var pendientes = Model.Where(p => p.Estado == "PENDIENTE").ToList();
    var enCamino = Model.Where(p => p.Estado == "EN CAMINO").ToList();
    var entregados = Model.Where(p => p.Estado == "ENTREGADO").ToList();
}

<div id="admin-content-partial">
    <div class="mb-4">
        <h2 class="fw-bold" style="color: var(--primary-hard)">Gestión de Pedidos</h2>
        <p class="text-muted">Supervisa la preparación de los productos por parte de los agricultores.</p>
    </div>

    <div class="stats-container animate-fade-in">
        <div class="stat-card" style="border-top: 4px solid var(--primary-color)">
            <span class="stat-label"><i class="bi bi-graph-up-arrow me-2"></i>Ganancia Neta</span>
            <span class="stat-value" style="color: var(--primary-color)">@ViewBag.TotalNeto.ToString("C")</span>
        </div>
        <div class="stat-card">
            <span class="stat-label"><i class="bi bi-cash-stack me-2"></i>Ventas Brutas</span>
            <span class="stat-value">@ViewBag.TotalBruto.ToString("C")</span>
        </div>
        <div class="stat-card">
            <span class="stat-label"><i class="bi bi-truck-flatbed me-2"></i>Pago Agricultores</span>
            <span class="stat-value text-accent">@ViewBag.TotalAgricultores.ToString("C")</span>
        </div>
        <div class="stat-card" style="border-top: 4px solid var(--primary-color)">
            <span class="stat-label"><i class="bi bi-bag-check me-2"></i>Total Pedidos</span>
            <span class="stat-value">@ViewBag.TotalPedidos</span>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#pendientes">
                Pendientes <span class="badge bg-danger ms-1">@pendientes.Count</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#enCamino">
                En Camino <span class="badge bg-warning ms-1">@enCamino.Count</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#entregados">
                Entregados <span class="badge bg-success ms-1">@entregados.Count</span>
            </a>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="pendientes">
            @if (!pendientes.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
                    <h5 class="text-muted">No hay pedidos pendientes</h5>
                </div>
            }
            else
            {
                @foreach (var p in pendientes)
                {
                    bool todoListo = p.DetallesPedido != null && p.DetallesPedido.Any() && p.DetallesPedido.All(d => d.Listo);
                    <div class="ordermgr-card mb-3">
                        <div class="ordermgr-header" data-bs-toggle="collapse" data-bs-target="#collapsePedido-@p.IdPedido">
                            <div class="ordermgr-summary">
                                <span class="ordermgr-id">PEDIDO #@p.IdPedido</span>
                                <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i> @p.FechaPedido.ToShortDateString()</span>
                                <span class="text-muted small"><i class="bi bi-person me-1"></i> @p.Cliente.Nombre</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="fw-bold">@p.Total.ToString("C")</span>
                                <i class="bi bi-chevron-down"></i>
                            </div>
                        </div>

                        <div id="collapsePedido-@p.IdPedido" class="collapse show">
                            <div class="ordermgr-detail-box">
                                @await Html.PartialAsync("_DetallesPedido", p)

                                <div class="ordermgr-footer mt-3">
                                    <div>
                                        @if (!todoListo)
                                        {
                                            <small class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i> Falta confirmación de agricultores.</small>
                                        }
                                        else
                                        {
                                            <small class="text-success"><i class="bi bi-check-all me-1"></i> Listo para enviar.</small>
                                        }
                                    </div>
                                    <form asp-action="CambiarEstadoEnCamino" method="post" class="ajax-form">
                                        <input type="hidden" name="idPedido" value="@p.IdPedido" />
                                        <button type="submit" class="btn-shipment" @(todoListo ? "" : "disabled")>
                                            <i class="bi bi-truck me-2"></i> CONFIRMAR ENVÍO
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="tab-pane fade" id="enCamino">
            @if (!enCamino.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-truck fs-1 text-muted d-block mb-3"></i>
                    <h5 class="text-muted">No hay pedidos en camino</h5>
                </div>
            }
            else
            {
                @foreach (var p in enCamino)
                {
                    <div class="ordermgr-card mb-3">
                        <div class="ordermgr-header" data-bs-toggle="collapse" data-bs-target="#detailsEnCamino-@p.IdPedido">
                            <div class="ordermgr-summary">
                                <span class="ordermgr-id">PEDIDO #@p.IdPedido</span>
                                <span class="badge bg-info ms-2">En Camino</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="fw-bold">@p.Total.ToString("C")</span>
                                <i class="bi bi-chevron-down"></i>
                            </div>
                        </div>
                        <div id="detailsEnCamino-@p.IdPedido" class="collapse">
                            <div class="ordermgr-detail-box">
                                @await Html.PartialAsync("_DetallesPedido", p)
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="tab-pane fade" id="entregados">
            @if (!entregados.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-check-circle fs-1 text-muted d-block mb-3"></i>
                    <h5 class="text-muted">No hay pedidos entregados</h5>
                </div>
            }
            else
            {
                @foreach (var p in entregados)
                {
                    <div class="ordermgr-card mb-3">
                        <div class="ordermgr-header" data-bs-toggle="collapse" data-bs-target="#detailsEntregados-@p.IdPedido">
                            <div class="ordermgr-summary">
                                <span class="ordermgr-id">PEDIDO #@p.IdPedido</span>
                                <span class="badge bg-success ms-2">Entregado</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="fw-bold">@p.Total.ToString("C")</span>
                                <i class="bi bi-chevron-down"></i>
                            </div>
                        </div>
                        <div id="detailsEntregados-@p.IdPedido" class="collapse">
                            <div class="ordermgr-detail-box">
                                @await Html.PartialAsync("_DetallesPedido", p)
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>