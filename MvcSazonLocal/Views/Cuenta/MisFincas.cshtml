@model List<Finca>

<div id="main-content-partial">
    <div class="fincas-container animate-fade-in">
        <div class="header-flex mb-5">
            <div>
                <h4 class="fw-bold text-main">Mis Fincas</h4>
                <p class="text-muted">Gestiona las ubicaciones de tus cultivos en Sazón Local.</p>
            </div>
            <a asp-action="CrearFinca" class="btn-primary-custom ajax-link">
                <i class="bi bi-plus-lg me-2"></i> Registrar Nueva Finca
            </a>
        </div>

        <div class="fincas-grid">
            @foreach (var finca in Model)
            {
                <div class="finca-card shadow-sm">
                    <div class="finca-header-status @(finca.EstaActiva ? "" : "finca-disabled")">
                        @if (finca.EstaValidada == 1)
                        {
                            <span class="badge badge-pending"><i class="bi bi-clock me-1"></i> Pendiente</span>
                        }
                        else if (finca.EstaValidada == 2)
                        {
                            <span class="badge badge-approved"><i class="bi bi-check-circle me-1"></i> Validada</span>
                        }
                        else if(finca.EstaValidada == 3)
                        {
                            <span class="badge badge-rejected"><i class="bi bi-x-circle me-1"></i> Rechazada</span>
                        }

                        <span class="status-dot @(finca.EstaActiva ? "dot-online" : "dot-offline")"
                              title="@(finca.EstaActiva ? "Visible en la web" : "Oculta para clientes")">
                        </span>
                    </div>
                    <div class="finca-body">
                        <div class="finca-icon">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <div class="finca-info">
                            <h5 class="fw-bold text-main mb-1">@finca.Nombre</h5>
                            <p class="small text-muted mb-1"><i class="bi bi-map me-1"></i> @finca.Municipio, @finca.Provincia</p>
                            <p class="small text-muted"><i class="bi bi-signpost-split me-1"></i> @finca.Direccion</p>
                        </div>
                    </div>

                    <div class="finca-footer mt-3 pt-3 border-top d-flex gap-2">
                        <a asp-action="EditarFinca" asp-route-id="@finca.IdFinca" class="btn-finca-action edit flex-grow-1 ajax-link">
                            <i class="bi bi-pencil-square me-1"></i> Editar
                        </a>
                        <form asp-action="CambiarEstadoFinca" method="post" class="m-0 ajax-form">
                            <input type="hidden" name="idFinca" value="@finca.IdFinca" />
                            <button type="submit" class="btn-status-toggle @(finca.EstaActiva ? "active" : "inactive")"
                                    title="@(finca.EstaActiva ? "Desactivar Finca" : "Activar Finca")">
                                <i class="bi @(finca.EstaActiva ? "bi-eye-fill" : "bi-eye-slash-fill")"></i>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</div>