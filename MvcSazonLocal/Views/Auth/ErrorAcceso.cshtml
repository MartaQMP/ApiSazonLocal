@section style {
    <link rel="stylesheet" href="~/css/views/auth/error-acceso.css" asp-append-version="true" />
}

<div class="error-acceso-container">
    <article class="error-card">
        <div class="error-card-body">
            <div class="error-icon-wrapper">
                <i class="bi bi-shield-lock-fill error-icon"></i>
            </div>

            <h1 class="error-title">¡Zona restringida!</h1>

            <p class="error-text">
                Parece que has intentado tomar un atajo por una zona de la finca que no te corresponde.
                Tu nivel de acceso actual no permite ver este contenido.
            </p>

            <div class="error-actions">
                <a asp-controller="Productos" asp-action="Productos" class="btn-sazon-primary">
                    Volver a los Productos
                </a>

                <a href="mailto:sazonlocal.sl@gmail.com" class="btn-sazon-link">
                    Solicitar acceso al administrador
                </a>
            </div>
        </div>

        <footer class="error-card-footer">
            Sazón Local &copy; @DateTime.Now.Year - Seguridad del Sistema
        </footer>
    </article>
</div>