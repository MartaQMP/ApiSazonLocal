@section style{
    <link rel="stylesheet" href="~/css/views/auth/logIn.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h3>Sazón Local</h3>
            <p class="mb-0">Bienvenido de nuevo</p>
        </div>
        <div class="card-body-auth">
            @if (ViewBag.Mensaje != null)
            {
                <div class="alert alert-auth alert-success-sazon alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@ViewBag.Mensaje
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }


            @if (ViewBag.PendientesHash > 0)
            {
                <div class="mantenimiento-wrapper">
                    <form asp-action="ActualizarPassword" method="post">
                        <button type="submit" class="btn-outline-warning">
                            <i class="bi bi-shield-lock"></i>
                            Segurizar (@ViewBag.PendientesHash)
                        </button>
                    </form>
                </div>
            }
            @if (ViewBag.MensajeError != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4 alert-auth" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @ViewBag.MensajeError
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <form method="post">
                <input type="hidden" name="estaComprando" value="@(ViewBag.Comprando.ToString().ToLower())" />
                <div class="mb-3">
                    <label class="form-label-auth text-uppercase">Correo Electrónico</label>
                    <input name="email" type="email" class="form-control-auth" placeholder="ejemplo@correo.com" required />
                </div>
                <div class="mb-4">
                    <label class="form-label-auth text-uppercase">Contraseña</label>
                    <div class="input-group-auth position-relative">
                        <input id="password" name="password" type="password" class="form-control-auth" placeholder="••••••••" required />
                        <button type="button" id="togglePassword" class="btn-toggle-pw">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>
                <button type="submit" class="btn-auth">
                    ENTRAR
                </button>
            </form>
        </div>
        <div class="auth-footer">
            <div class="mb-3">
                <a  asp-action="OlvidePassword" class="auth-link small olvide">
                    ¿Has olvidado tu contraseña?
                </a>
            </div>

            <hr style="border-top: 1px solid var(--border-line); width: 80%; margin: 15px auto;" />
            <span class="small text-muted">¿No tienes cuenta?</span>
            <br />
            <a  asp-action="Register" class="auth-link">
                ¡REGÍSTRATE AQUÍ!
            </a>
        </div>
    </div>
</div>
<div class="text-center mt-3">
    <a asp-controller="Productos" asp-action="Productos" class="text-muted small text-decoration-none">
        ← Volver a la tienda
    </a>
</div>

@section Scripts {
    <script>
        document.getElementById("togglePassword").addEventListener("click", function () {
            const passwordInput = document.getElementById("password");
            const eyeIcon = document.getElementById("eyeIcon");

            const isPassword = passwordInput.getAttribute("type") === "password";
            passwordInput.setAttribute("type", isPassword ? "text" : "password");

            eyeIcon.classList.toggle("bi-eye");
            eyeIcon.classList.toggle("bi-eye-slash");
        });
    </script>
}