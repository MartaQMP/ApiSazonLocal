@section style {
    <link rel="stylesheet" href="~/css/views/auth/cambiar-contrasena.css" asp-append-version="true" />
}

<div class="auth-container">
    <h2 class="auth-title">¿Olvidaste tu clave?</h2>
    <p class="auth-subtitle">Dinos tu email y te enviaremos un código para que puedas entrar de nuevo.</p>

    @if (ViewBag.MensajeError != null)
    {
        <div class="error-msg">
            <i class="fas fa-exclamation-circle"></i> @ViewBag.MensajeError
        </div>
    }

    <form asp-action="OlvidePassword" method="post">
        <div class="form-group-custom">
            <label>Correo Electrónico</label>
            <input type="email" name="email" class="form-control-custom" placeholder="Tu email de Sazón Local" required />
        </div>

        <button type="submit" class="btn-auth-primary">Enviar Código de Seguridad</button>

        <div style="text-align: center; margin-top: 25px;">
            <a asp-action="LogIn" class="auth-link">Volver al inicio de sesión</a>
        </div>
    </form>
</div>