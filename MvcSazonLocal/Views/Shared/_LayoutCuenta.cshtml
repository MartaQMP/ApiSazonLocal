@using System.Security.Claims;
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sazón Local</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/layout-cuenta.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/mapas/css/leaflet.css" />

    <link rel="stylesheet" href="~/css/views/cuenta/perfil.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/cuenta/direcciones.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/cuenta/crear-direccion.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/cuenta/seguridad.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/cuenta/mis-productos.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/cuenta/crear-producto.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/cuenta/mis-fincas.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/cuenta/gestionar-fincas.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/cuenta/pedidos.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/views/cuenta/pedidos-pendientes.css" asp-append-version="true" />
    @RenderSection("style", false)
</head>
<body>
    @await Html.PartialAsync("_Navbar")
    <div class="d-flex wrapper-gestion">
        <nav class="sidebar-gestion border-end shadow-sm bg-white">
            <div class="p-4 border-bottom mb-2">
                <h5 class="fw-bold text-olive mb-0"><i class="bi bi-person-badge me-2"></i>Mi Cuenta</h5>
                <small class="text-muted">Centro de Gestión</small>
            </div>

            <div class="list-group list-group-flush px-3">
                <p class="text-uppercase small fw-bold text-muted mb-2 mt-3 px-2">General</p>
                <a asp-controller="Cuenta" asp-action="Perfil"
                   class="list-group-item list-group-item-action item-menu-gestion ajax-nav @(ViewContext.RouteData.Values["Action"].ToString() == "Perfil" ? "active" : "")">
                    <i class="bi bi-person-vcard me-2"></i> Mis Datos
                </a>
                <a asp-controller="Cuenta" asp-action="Direcciones"
                   class="list-group-item list-group-item-action item-menu-gestion ajax-nav @(ViewContext.RouteData.Values["Action"].ToString() == "Direcciones" ? "active" : "")">
                    <i class="bi bi-geo-alt me-2"></i> Mis Direcciones
                </a>
                <a asp-controller="Cuenta" asp-action="Pedidos"
                   class="list-group-item list-group-item-action item-menu-gestion ajax-nav @(ViewContext.RouteData.Values["Action"].ToString() == "Pedidos" ? "active" : "")">
                    <i class="bi bi-bag-check me-2"></i> Mis Compras
                </a>
                <a asp-controller="Cuenta" asp-action="Seguridad"
                   class="list-group-item list-group-item-action item-menu-gestion ajax-nav @(ViewContext.RouteData.Values["Action"].ToString() == "Seguridad" ? "active" : "")">
                    <i class="bi bi-bag-check me-2"></i> Seguridad
                </a>

                @if (User.IsInRole("AGRICULTOR"))
                {
                    <p class="text-uppercase small fw-bold text-muted mb-2 mt-4 px-2 border-top pt-3">Gestión Profesional</p>
                    <a asp-controller="Cuenta" asp-action="PedidosPendientes"
                       class="list-group-item list-group-item-action item-menu-gestion ajax-nav @(ViewContext.RouteData.Values["Action"].ToString() == "PedidosPendientes" ? "active" : "")">
                        <i class="bi bi-graph-up-arrow me-2"></i> Pedidos Recibidos
                    </a>
                    <a asp-controller="Cuenta" asp-action="MisProductos"
                       class="list-group-item list-group-item-action item-menu-gestion ajax-nav @(ViewContext.RouteData.Values["Action"].ToString() == "MisProductos" ? "active" : "")">
                        <i class="bi bi-egg-fried me-2"></i> Mis Productos
                    </a>
                    <a asp-controller="Cuenta" asp-action="MisFincas"
                       class="list-group-item list-group-item-action item-menu-gestion ajax-nav @(ViewContext.RouteData.Values["Action"].ToString() == "MisFincas" ? "active" : "")">
                        <i class="bi bi-map me-2"></i> Mis Fincas
                    </a>
                }
            </div>
        </nav>

        <main class="main-content-gestion bg-light-soft">
            <header class="navbar navbar-expand navbar-light bg-white shadow-sm px-4 mb-4">
                <button class="btn btn-link d-md-none me-3">
                    <i class="bi bi-list fs-3 text-olive"></i>
                </button>
                <span class="navbar-text fw-bold text-olive">Panel de Control</span>
            </header>

            <div class="container-fluid px-lg-5 pb-5" id="main-content">
                @RenderBody()
            </div>
        </main>
    </div>
    @await Html.PartialAsync("_Footer")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/mapas/js/leaflet.js"></script>
    @RenderSection("Scripts", required: false)
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            function ejecutarScripts(contenedor) {
                const scripts = contenedor.querySelectorAll('script');

                const scriptsArray = Array.from(scripts);

                function cargarSiguiente(index) {
                    if (index >= scriptsArray.length) return;

                    const scriptViejo = scriptsArray[index];
                    const scriptNuevo = document.createElement('script');

                    Array.from(scriptViejo.attributes).forEach(attr => {
                        scriptNuevo.setAttribute(attr.name, attr.value);
                    });
                    scriptNuevo.textContent = scriptViejo.textContent;

                    if (scriptViejo.src) {
                        scriptNuevo.onload = () => cargarSiguiente(index + 1);
                        scriptViejo.parentNode.replaceChild(scriptNuevo, scriptViejo);
                    } else {
                        scriptViejo.parentNode.replaceChild(scriptNuevo, scriptViejo);
                        cargarSiguiente(index + 1);
                    }
                }
                cargarSiguiente(0);
            }

            function normalizarUrl(u) {
                return u.toLowerCase().replace(/\/$/, '');
            }

            function actualizarActivo(url) {
                const enlaces = Array.from(document.querySelectorAll('.ajax-nav'));
                enlaces.forEach(l => l.classList.remove('active'));

                const activeLink = enlaces.find(l => normalizarUrl(l.href) === normalizarUrl(url));

                if (activeLink) activeLink.classList.add('active');
            }

            function cargarContenido(url) {
                const content = document.getElementById('main-content');
                content.style.transition = 'opacity 0.15s ease';
                content.style.opacity = '0.4';

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(res => res.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newContent = doc.getElementById('main-content-partial');

                    if (newContent) {
                        content.innerHTML = newContent.innerHTML;
                        ejecutarScripts(content);
                    }

                    content.style.opacity = '1';
                    history.pushState(null, '', url);
                    actualizarActivo(url);
                })
                .catch(() => {
                    window.location.href = url;
                });
            }

            document.querySelectorAll('.ajax-nav').forEach(link => {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    cargarContenido(this.href);
                });
            });

            document.addEventListener('submit', function(e) {
                const form = e.target;
                if (!form.classList.contains('ajax-form')) return;

                e.preventDefault();
                const formData = new FormData(form);

                fetch(form.action, {
                    method: 'POST',
                    body: formData
                })
                .then(() => {
                    cargarContenido(window.location.pathname);
                })
                .catch(() => {
                    form.submit();
                });
            });

            document.addEventListener('click', function(e) {
                const link = e.target.closest('.ajax-link');
                if (!link) return;

                e.preventDefault();
                cargarContenido(link.href);
            });

            window.addEventListener('popstate', function () {
                cargarContenido(location.href);
            });

        });
    </script>
</body>
</html>