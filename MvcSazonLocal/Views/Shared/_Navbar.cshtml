@using System.Security.Claims
@{
    string nombre = User.Identity.Name;
}
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm custom-bg border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a asp-controller="Productos" asp-action="Productos" class="navbar-brand">
                <img src="~/images/Logo_Sazon_Local.png" style="width: 85px" alt="Logo Sazón Local" />
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse d-sm-inline-flex">

                <ul class="navbar-nav flex-grow-1 justify-content-center">
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" asp-controller="Productos" asp-action="Productos">Productos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom" asp-controller="Fincas" asp-action="Fincas">Fincas</a>
                    </li>
                    @if (!User.IsInRole("ADMINISTRADOR"))
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="AtencionUsuario" asp-action="Contacto">Contacto</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="AtencionUsuario" asp-action="BuzonMensajes">Buzon Mensajes</a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav align-items-center">
                    <li class="nav-item">
                        <a class="nav-link nav-link-custom nav-cart" asp-controller="Compra" asp-action="Carrito">
                            <i class="bi bi-cart3 fs-5"></i>
                            @await Component.InvokeAsync("CantidadCarrito")
                        </a>
                    </li>

                    @if (!User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item nav-user-item">
                            <a class="nav-link nav-link-custom" asp-controller="Auth" asp-action="LogIn">
                                <i class="bi bi-person-circle me-1"></i> Login
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item dropdown nav-user-item">
                            <a class="nav-link nav-link-custom dropdown-toggle" href="#" id="profileDropdown" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-2"></i> Mi Cuenta
                            </a>
                            <ul class="dropdown-menu dropdown-custom dropdown-menu-end shadow border-0 mt-2">
                                <li><h6 class="dropdown-header">Hola, @nombre</h6></li>
                                @if (User.IsInRole("CLIENTE") || User.IsInRole("AGRICULTOR"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Cuenta" asp-action="Perfil"><i class="bi bi-person-fill"></i> Mi Cuenta</a>
                                    </li>
                                }
                                else if (User.IsInRole("ADMINISTRADOR"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="GestionPedidos"><i class="bi bi-person-fill"></i> Panel de Control</a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item logout-link" asp-controller="Auth" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>